# Killer Game API environment variables.
# Copy to `.env` and fill in the values. Never commit real secrets.

# Stripe keys for one-shot premium upgrade payments.
# STRIPE_SECRET_KEY      - sk_test_... / sk_live_...  (server-only, never expose to the client)
# STRIPE_WEBHOOK_SECRET  - whsec_...                  (from the Stripe Dashboard webhook endpoint)
# STRIPE_PRICE_ID        - price_...                  (the one-shot Price created in Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Public site origin, used to build Stripe Checkout success/cancel URLs.
# Defaults to https://the-killer.online if unset.
NEXT_PUBLIC_SITE_URL=https://the-killer.online